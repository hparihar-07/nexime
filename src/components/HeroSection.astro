---
import { Image } from "astro:assets";
import homeImg from "../assets/home.jpg";
---
<section id="hero" class="relative pt-32 pb-20 overflow-hidden flex flex-col items-center text-center">
  <div class="container mx-auto px-6 relative z-10 flex flex-col items-center">
    
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-500/10 text-orange-400 text-xs font-medium ring-1 ring-orange-500/20 mb-8 animate-[fade-in_1s_ease-out]">
      <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
      Nexime 1.0 is now available
    </div>
    
    <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl font-semibold tracking-tighter text-transparent bg-clip-text bg-linear-to-b from-white to-neutral-500 mb-6 max-w-5xl animate-[fade-in-up_1s_ease-out_forwards] opacity-0">
      Your next <span class="text-orange-500">anime</span>,<br/>intelligently chosen.
    </h1>
    
    <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mb-12 animate-[fade-in-up_1s_ease-out_0.2s_forwards] opacity-0">
      Built to solve the modern streaming problem of decision fatigue. Nexime learns your tastes and serves hyper-personalized recommendations powered by a real-time, local-first architecture.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 mb-24 animate-[fade-in-up_1s_ease-out_0.4s_forwards] opacity-0">
      <a href="/Nexime.apk" download="Nexime.apk" class="px-8 py-4 bg-orange-500 text-black rounded-full font-semibold hover:scale-105 transition-transform duration-300 shadow-[0_0_20px_rgba(249,115,22,0.3)]">
        Download for Android
      </a>
      <a href="#screens" class="px-8 py-4 bg-white/5 hover:bg-white/10 text-white rounded-full font-semibold ring-1 ring-white/10 transition-colors duration-300">
        Explore Architecture
      </a>
    </div>

    <div class="relative w-full max-w-5xl flex justify-center animate-[fade-in-up_1s_ease-out_0.6s_forwards] opacity-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60%] h-[20%] bg-orange-600/30 blur-[100px] rounded-full pointer-events-none"></div>
      
      <div class="relative z-10 w-70 h-146.75 md:w-[320px] md:h-168 rounded-[3rem] ring-10 ring-slate-300 border-[6px] border-black overflow-hidden shadow-[0_20px_80px_rgba(249,115,22,0.15)] flex flex-col bg-black">
        
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-black rounded-b-2xl z-20 flex items-center justify-center">
             <div class="w-12 h-1.5 bg-neutral-800 rounded-full opacity-60"></div>
        </div>
        
        <Image 
          src={homeImg} 
          alt="Nexime Home Screen" 
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 w-full h-full object-cover object-top z-10" 
        />
        
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes fade-in-up {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }
</style>