---
import { Image } from "astro:assets";
import NexLogo from '../assets/nexLogo.png';

const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-white/10 bg-black pt-16 pb-8 mt-20 relative z-20">
  <div class="container mx-auto px-6 max-w-5xl flex flex-col gap-10">
    
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      
      <div class="flex items-center gap-3 opacity-50 hover:opacity-100 transition-opacity">
        <Image 
          src={NexLogo} 
          alt="Nexime Fox Logo" 
          class="w-6 h-6 object-contain grayscale" 
          loading="lazy"
        />
        <span class="text-white font-medium tracking-tight hover:text-orange-400 transition-colors">Nexime</span>
      </div>

      <div class="text-neutral-500 text-sm font-medium flex items-center gap-1.5">
        Created with <span class="bg-orange-500 bg-clip-text text-transparent">❤</span> by
        
        <a 
          href="https://0xhparihar07.vercel.app" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group relative inline-grid overflow-hidden font-semibold"
        >
          <span class="col-start-1 row-start-1 text-neutral-300 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-full group-hover:opacity-0 group-hover:blur-sm">
            0xhparihar07
          </span>
          
          <span class="col-start-1 row-start-1 text-orange-400 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] translate-y-full opacity-0 blur-sm group-hover:translate-y-0 group-hover:opacity-100 group-hover:blur-none drop-shadow-[0_0_8px_rgba(249,115,22,0.5)]">
            lordsama
          </span>
        </a>
      </div>

      <div class="flex items-center gap-6 text-neutral-500">
        
        <a 
          href="https://github.com/hparihar-07" 
          target="_blank" 
          rel="noopener noreferrer" 
          aria-label="GitHub Profile"
          class="hover:text-orange-400 hover:scale-110 transition-all duration-300"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
        </a>

        <a 
          href="https://twitter.com/hparihar07" 
          target="_blank" 
          rel="noopener noreferrer" 
          aria-label="X (Twitter) Profile"
          class="hover:text-orange-400 hover:scale-110 transition-all duration-300"
        >
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>

      </div>
      
    </div>

    <div class="flex flex-col-reverse md:flex-row justify-between items-center gap-4 pt-8 border-t border-white/5 text-xs text-neutral-600 font-medium">
      
      <div>
        &copy; {currentYear} Nexime. All rights reserved.
      </div>

      <a 
        href="#top" 
        class="group flex items-center gap-2 hover:text-orange-400 transition-colors"
        aria-label="Scroll to top"
      >
        <span>Back to top</span>
        <div class="w-8 h-8 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center group-hover:bg-orange-500/10 group-hover:ring-orange-500/30 transition-all duration-300">
          <svg class="w-4 h-4 text-neutral-400 group-hover:text-orange-400 group-hover:-translate-y-0.5 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
          </svg>
        </div>
      </a>

    </div>

  </div>
</footer>