---
---

<section id="tech-highlights" class="py-32 relative">
  <div class="container mx-auto px-6 max-w-5xl">
    
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-semibold font-heading tracking-tighter text-transparent bg-clip-text bg-linear-to-b from-white to-neutral-500 mb-4">
        Engineering Excellence.
      </h2>
      <p class="text-lg text-neutral-400 font-medium max-w-2xl mx-auto">
        Built strictly with modern mobile engineering practices, prioritizing performance, offline capabilities, and type safety.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <div class="md:col-span-2 group relative overflow-hidden rounded-4xl bg-white/2 ring-1 ring-white/10 p-10 md:p-14 flex flex-col md:flex-row items-center gap-10 hover:bg-white/4 transition-colors duration-500">
        <div class="absolute top-0 right-0 w-96 h-96 bg-orange-500/10 blur-[100px] rounded-full pointer-events-none group-hover:bg-orange-500/20 transition-colors duration-700"></div>
        
        <div class="flex-1 relative z-10">
          <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center mb-6 ring-1 ring-white/20">
            <svg class="w-6 h-6 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
          </div>
          <h3 class="text-3xl font-semibold text-white mb-4 tracking-tight">Frictionless Onboarding</h3>
          <p class="text-neutral-400 text-lg leading-relaxed">
            Forget your passwords. Powered by <span class="text-white font-medium">InstantDB Magic Links</span>, Nexime uses secure, one-time codes sent directly to your email. You are in, instantly.
          </p>
        </div>
        
        <div class="flex-1 w-full max-w-sm bg-black/50 rounded-2xl ring-1 ring-white/10 p-6 shadow-2xl relative z-10">
           <div class="h-4 w-24 bg-neutral-800 rounded mb-6"></div>
           <div class="w-full h-12 bg-white/5 rounded-xl border border-white/10 flex items-center px-4 mb-4">
             <span class="text-neutral-500 text-sm">user@nexime.com</span>
           </div>
           <div class="w-full h-12 bg-orange-600 rounded-xl flex items-center justify-center text-white font-semibold shadow-[0_0_20px_rgba(234,88,12,0.3)]">
             Send Magic Code
           </div>
        </div>
      </div>

      <div class="group relative overflow-hidden rounded-4xl bg-white/2 ring-1 ring-white/10 p-10 hover:bg-white/4 transition-colors duration-500">
        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center mb-6 ring-1 ring-white/20 relative z-10">
          <svg class="w-6 h-6 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <h3 class="text-2xl font-semibold text-white mb-3 tracking-tight relative z-10">60fps Native Performance</h3>
        <p class="text-neutral-400 relative z-10">
          Utilizing optimized <code class="text-white font-mono text-sm">FlatList</code> rendering and native splash-screen handoffs to eliminate UI jitter and fake loading spinners.
        </p>
      </div>

      <div class="group relative overflow-hidden rounded-4xl bg-white/2 ring-1 ring-white/10 p-10 hover:bg-white/4 transition-colors duration-500">
        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center mb-6 ring-1 ring-white/20 relative z-10">
          <svg class="w-6 h-6 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        </div>
        <h3 class="text-2xl font-semibold text-white mb-3 tracking-tight relative z-10">Intelligent Rate-Limiting</h3>
        <p class="text-neutral-400 relative z-10">
          A custom, zero-dependency API client interacts safely with AniList GraphQL, recursively intercepting HTTP 429 errors to guarantee crash-free browsing.
        </p>
      </div>

    </div>
  </div>
</section>