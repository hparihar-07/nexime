---
import { Image } from "astro:assets";
import nexLogo from "../assets/nexLogo.png";
---
<nav 
  id="premium-navbar" 
  class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[90%] max-w-4xl bg-black/40 backdrop-blur-2xl ring-1 ring-white/10 rounded-full shadow-2xl transition-all duration-500 ease-out px-6 py-3"
>
  <div class="flex items-center justify-between">
    
    <a href="/" class="text-xl font-medium font-heading tracking-tight flex items-center gap-3 hover:opacity-80 transition-opacity">
      <Image 
        src={nexLogo} 
        loading="eager"
        alt="Nexime Fox" 
        class="w-8 h-8 rounded-full object-contain drop-shadow-[0_0_12px_rgba(249,115,22,0.4)]" 
      />
      Nexime
    </a>

    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-neutral-400">
      <a href="#hero" class="hover:text-orange-500 transition-colors">Overview</a>
      <a href="#screens" class="hover:text-orange-500 transition-colors">Interface</a>
      <a href="#tech" class="hover:text-orange-500 transition-colors">Architecture</a>
    </div>

    <a href="/Nexime.apk" download="Nexime.apk" class="flex items-center justify-center px-5 py-2 text-sm font-semibold text-white bg-orange-500 hover:bg-black hover:text-orange-500 ring-1 ring-white/20 rounded-full transition-all duration-300">
      Get the App
    </a>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('premium-navbar');
    if (navbar) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          navbar.classList.add('bg-black/70');
          navbar.classList.remove('bg-black/40');
        } else {
          navbar.classList.add('bg-black/40');
          navbar.classList.remove('bg-black/70');
        }
      }, { passive: true });
    }
  });
</script>